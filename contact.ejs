<%- include('partials/header', { title: 'Contact', artistName: artistName }) %>

<div style="padding-top: 6rem;"></div>

<section>
  <div class="section-header fade-in">
    <span class="section-tag">✦ Get in Touch</span>
    <h1 class="section-title">Book a Design</h1>
    <div class="divider"></div>
    <p class="section-desc">I'd love to create something beautiful for you — bridal, festive, or custom</p>
  </div>

  <div class="contact-wrap fade-in-delay">

    <% if (success) { %>
    <div class="message-box success-box">
      🌿 Thank you! Your message has been sent. I'll get back to you soon.
    </div>
    <div style="text-align:center; margin-top:1rem;">
      <a href="/contact" class="btn" style="font-size:0.75rem;">Send Another</a>
    </div>
    <% } else { %>
    <form action="/contact" method="POST">
      <div class="form-group">
        <label>Your Name *</label>
        <input type="text" name="name" placeholder="Enter your full name" required />
      </div>
      <div class="form-group">
        <label>Phone / WhatsApp</label>
        <input type="tel" name="phone" placeholder="+91 XXXXX XXXXX" />
      </div>
      <div class="form-group">
        <label>Email Address</label>
        <input type="email" name="email" placeholder="your@email.com" />
      </div>
      <div class="form-group">
        <label>Occasion</label>
        <select name="occasion">
          <option value="">Select occasion...</option>
          <option>Bridal / Wedding</option>
          <option>Eid / Festival</option>
          <option>Diwali / Navratri</option>
          <option>Birthday / Party</option>
          <option>Custom Design</option>
          <option>Other</option>
        </select>
      </div>
      <div class="form-group">
        <label>Message</label>
        <textarea name="message" placeholder="Tell me about the design you have in mind..."></textarea>
      </div>
      <button type="submit" class="btn btn-filled" style="width:100%; cursor:pointer;">Send Message ✦</button>
    </form>
    <% } %>

    <div style="margin-top:3rem; padding-top:2rem; border-top:1px solid rgba(196,146,42,0.15); display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; text-align:center;">
      <div>
        <p style="font-size:0.7rem; letter-spacing:0.3em; text-transform:uppercase; color:var(--gold); margin-bottom:0.5rem;">Location</p>
        <p style="font-family:'Playfair Display',serif; font-style:italic; color:var(--muted); opacity:0.8;">Pune, Maharashtra</p>
      </div>
      <div>
        <p style="font-size:0.7rem; letter-spacing:0.3em; text-transform:uppercase; color:var(--gold); margin-bottom:0.5rem;">Available For</p>
        <p style="font-family:'Playfair Display',serif; font-style:italic; color:var(--muted); opacity:0.8;">Bridal · Festive · Events</p>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer', { artistName: artistName }) %>
